<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <handlers>
      <add name="Python FastCGI"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="C:\inetpub\wwwroot\horizonzero\venv\Scripts\python.exe|C:\inetpub\wwwroot\horizonzero\venv\Lib\site-packages\wfastcgi.py"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <appSettings>
      <add key="WSGI_HANDLER"           value="HorizonZero.wsgi.application" />
      <add key="PYTHONPATH"             value="C:\inetpub\wwwroot\horizonzero" />
      <add key="DJANGO_SETTINGS_MODULE" value="HorizonZero.settings" />
    </appSettings>

    <staticContent>
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <mimeMap fileExtension=".woff"  mimeType="font/woff"  />
    </staticContent>

  </system.webServer>
</configuration>